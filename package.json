{
	"name": "firestart",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"content": "node scripts/build-content.js",
		"cv": "node --env-file=.env scripts/build-cv.js",
		"cv:check": "node --env-file=.env scripts/build-cv.js --check",
		"cv:pdf": "node --env-file=.env scripts/build-cv.js --skip-llm --pdf",
		"cv:all": "node --env-file=.env scripts/build-cv.js --pdf",
		"dev": "yarn content && vite dev",
		"build": "yarn content && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"undici": "^8.7.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@mdi/js": "^7.4.47",
		"marked": "^17.0.4",
		"yaml": "^2.8.1"
	}
}
